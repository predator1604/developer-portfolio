{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },

  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "portfolio_db",
    "ContactMessages": "contact_messages",
    "Projects": "projects",
    "SkillGroups": "skill_groups",
    "ChatSessions": "chat_sessions"
  },

  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@yourname.dev",
    "FromName": "Your Name Portfolio",
    "OwnerEmail": "your.email@example.com",
    "UseSsl": false
  },

  "AI": {
    "Provider": "OpenAI",
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "ModelId": "gpt-4o-mini",
    "Endpoint": "",
    "DeploymentName": ""
  },

  "AllowedOrigins": [
    "http://localhost:4200",
    "https://yourname.dev"
  ],

  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
