{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },

  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "portfolio_db_dev"
  },

  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "FromEmail": "dev@localhost",
    "FromName": "Portfolio Dev",
    "OwnerEmail": "dev@localhost",
    "UseSsl": false
  },

  "AI": {
    "Provider": "OpenAI",
    "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
    "ModelId": "gpt-4o-mini"
  },

  "AllowedOrigins": [
    "http://localhost:4200",
    "http://localhost:4201"
  ]
}
